# RustPBX Control Plane configuration (example).
# Copy to rustpbx-control.toml and adjust.

# gRPC server (config distribution, CDR, worker registry)
grpc_addr = "0.0.0.0:9090"

# HTTP server: admin console SPA + REST API
http_addr = "0.0.0.0:9080"

# Shared database with the rest of RustPBX (sqlite / mysql / postgres).
# The control plane ALTERs existing rustpbx_* tables to add tenant_id, so the
# base schema (created by the monolith / migrations) must already exist.
database_url = "sqlite://rustpbx-control.sqlite3"

# Super-admin login for the HTTP admin console. CHANGE THESE IN PRODUCTION.
admin_username = "admin"
admin_password = "admin"

# Directory containing the built SPA (run `bun run build` in web/).
web_dir = "crates/rustpbx-control/web/dist"

log = "info"
