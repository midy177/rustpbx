# RustPBX Media Worker — example configuration
# Deploy on any node; RTP must be publicly reachable (hostNetwork recommended).

control_plane_addr = "http://127.0.0.1:9090"
sip_addr = "0.0.0.0"
sip_port = 5070

# Public/external IP for RTP. Must be reachable by carriers.
# In K8s hostNetwork mode, set this to status.hostIP.
rtp_external_ip = "203.0.113.20"
rtp_bind_ip = "0.0.0.0"
rtp_start_port = 12000
rtp_end_port = 42000

max_concurrent = 100
worker_id = "worker-prod-01"
heartbeat_secs = 10

# Trusted Edge instances — SIP INVITEs from these IPs bypass ACL/Auth
# and are treated as internal calls (decoded via X-* headers).
trusted_edges = ["203.0.113.10", "10.0.0.0/8"]

# recording_path = "./recordings"
# database_url = "sqlite://rustpbx-worker.sqlite3"
# metrics_addr = "0.0.0.0:9100"
log = "info"
